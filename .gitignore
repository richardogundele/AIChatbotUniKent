# =============================================================
# FILE: .gitignore
# PROJECT: ChariotAI — AI Powered Student Support Chatbot
# PURPOSE: Prevents sensitive credentials and generated files
#          from being committed to the Git repository.
#
# PROTECTS:
#   terraform.tfvars     — Contains real Azure subscription IDs
#   *.tfstate            — Terraform state (may contain secrets)
#   backend/.env         — Azure API keys for local development
#   node_modules/        — Frontend dependencies (install via npm)
#   __pycache__/         — Python bytecode (auto-generated)
# =============================================================

# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/terraform.tfvars

# Backend
backend/.env
backend/__pycache__/
backend/*.pyc

# Frontend
frontend/node_modules/
frontend/dist/

# General
.env
*.log
venv/
